https://__token__:$(cat /run/secrets/gitlab_token)@gitlab.eopf.copernicus.eu/api/v4/projects/171/packages/pypi/simple \
https://__token__:$(cat /run/secrets/gitlab_token)@gitlab.eopf.copernicus.eu/api/v4/projects/102/packages/pypi/simple \
https://__token__:$(cat /run/secrets/gitlab_token)@gitlab.eopf.copernicus.eu/api/v4/projects/113/packages/pypi/simple \
