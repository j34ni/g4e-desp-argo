FROM quay.io/jupyter/minimal-notebook:2024-05-27

USER root
RUN apt-get update && apt-get upgrade -y && apt-get clean && rm -rf /var/lib/apt/lists/*
USER ${NB_USER}

COPY --chown=${NB_UID}:${NB_GID} synergy-processor /opt/s3syn

